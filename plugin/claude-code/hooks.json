{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "talon",
            "tool": "talon_hook_recall",
            "input": {
              "host": "claude-code",
              "sessionId": "${session_id}",
              "turnId": "${session_id}:${transcript_path}",
              "cwd": "${cwd}",
              "transcriptPath": "${transcript_path}",
              "message": "${prompt}",
              "budgetTokens": 500,
              "format": "hook-json"
            }
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "talon",
            "tool": "talon_hook_session_end",
            "input": {
              "host": "claude-code",
              "sessionId": "${session_id}"
            }
          }
        ]
      }
    ]
  }
}
